    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "optionalDependencies": {
    "markdownlint-rs-linux-x64": "0.3.8",
    "markdownlint-rs-linux-arm64": "0.3.8",
    "markdownlint-rs-darwin-x64": "0.3.8",
    "markdownlint-rs-darwin-arm64": "0.3.8",
    "markdownlint-rs-win32-x64": "0.3.8"
  }
