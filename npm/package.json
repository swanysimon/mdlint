{
  "name": "markdownlint-rs",
  "version": "0.3.8",
  "description": "Opinionated Markdown formatter and linter",
  "keywords": [
    "markdown",
    "linter",
    "formatter",
    "mdlint"
  ],
  "homepage": "https://github.com/swanysimon/mdlint",
  "bugs": "https://github.com/swanysimon/mdlint/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/swanysimon/mdlint.git",
    "directory": "npm"
  },
  "license": "Unlicense",
  "bin": {
    "mdlint": "bin/mdlint.js"
  },
  "engines": {
    "node": ">=14"
  },
  "os": [
